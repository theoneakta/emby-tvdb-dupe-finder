# Emby Duplicate Finder — Environment Variables
# Copy this file to .env and fill in your values

# Emby server URL — no trailing slash
EMBY_SERVER_URL=http://192.168.1.10:8096

# Emby API key
# Find it: Dashboard → Advanced → API Keys → New Key
EMBY_API_KEY=your_emby_api_key_here

# Emby admin credentials (required for file deletion)
EMBY_USERNAME=your_emby_username
EMBY_PASSWORD=your_emby_password

# Radarr URL and API key (optional)
# Find API key: Radarr → Settings → General → API Key
RADARR_URL=http://192.168.1.10:7878
RADARR_API_KEY=your_radarr_api_key_here

# Sonarr URL and API key (optional)
# Find API key: Sonarr → Settings → General → API Key
SONARR_URL=http://192.168.1.10:8989
SONARR_API_KEY=your_sonarr_api_key_here
